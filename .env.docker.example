# Copy this file to .env, then run:
# docker compose exec app php artisan key:generate

APP_NAME="PSA"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_PORT=8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=single
LOG_LEVEL=debug

DB_CONNECTION=mariadb
DB_HOST=db
DB_PORT=3306
DB_DATABASE=soundit_psa
DB_USERNAME=soundit_psa
DB_PASSWORD=soundit_psa
DB_ROOT_PASSWORD=soundit_psa_root

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=file

MAIL_MAILER=log

# Initial admin user. AdminSeeder aborts if unset. Set, run the seeder, then
# you can remove these from .env to keep credentials out of the env file.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Administrator

# Real SSO and integration secrets must be configured locally and never committed.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
MICROSOFT_REDIRECT_URI=http://localhost:8080/auth/microsoft/callback

PLIVO_WEBHOOK_SECRET=

# GRAPH_REQUEST_TIMEOUT=15
# GRAPH_TOKEN_TIMEOUT=10

AI_PROVIDER=anthropic
AI_API_KEY=
# AI_MODEL=
