# Copy this file to .env.production and fill in real values before running.
# Never commit real .env files or production secrets.
# Generate a real APP_KEY with: php artisan key:generate --show
# Use strong database passwords and store them in a secret manager where possible.
# Configure HTTPS/TLS at your reverse proxy or load balancer layer.
# Configure tested backups and recovery procedures for the MariaDB volume.

APP_NAME="PSA"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://example.com
APP_PORT=80

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=single
LOG_LEVEL=info

DB_CONNECTION=mariadb
DB_HOST=db
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

MYSQL_DATABASE=
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_ROOT_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=file

# Use log until SMTP or another production mail transport is configured.
MAIL_MAILER=log
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Administrator

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
MICROSOFT_REDIRECT_URI=https://example.com/auth/microsoft/callback

PLIVO_WEBHOOK_SECRET=

# GRAPH_REQUEST_TIMEOUT=15
# GRAPH_TOKEN_TIMEOUT=10

AI_PROVIDER=anthropic
AI_API_KEY=
# AI_MODEL=
