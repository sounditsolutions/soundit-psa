# Deploy targets for scripts/deploy.sh and the /deploy command.
# Copy this file to scripts/deploy.env and fill in your real values.
# scripts/deploy.env is gitignored — never commit real infrastructure values.

# SSH host: an entry in ~/.ssh/config, or user@hostname
DEPLOY_HOST=your-vps

# Absolute path to the app's deploy directory on the server
DEPLOY_PATH=/var/www/psa

# Public domain (no scheme) used for the live URL and health check
DEPLOY_DOMAIN=your-psa-domain
